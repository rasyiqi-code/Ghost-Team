datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int                  @id @default(autoincrement())
  email         String               @unique
  name          String
  emailVerified Boolean              @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  sessions      Session[]
  accounts      Account[]
  messages      Message[]
  files         File[]
  platforms     PlatformConnection[]
  aiProviders   AIProvider[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                Int       @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verifications")
}

model Message {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          String
  senderId          String   @map("sender_id")
  senderName        String?  @map("sender_name")
  content           String?
  messageType       String   @default("text") @map("message_type")
  fileId            Int?     @map("file_id")
  file              File?    @relation(fields: [fileId], references: [id], onDelete: SetNull)
  platformMessageId String?  @map("platform_message_id")
  isOutgoing        Boolean  @default(false) @map("is_outgoing")
  timestamp         DateTime @default(now())

  @@map("messages")
}

model File {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName  String    @map("original_name")
  storageUrl    String    @map("storage_url")
  fileType      String    @map("file_type")
  folder        String?
  sizeBytes     BigInt    @map("size_bytes")
  uploadedAt    DateTime  @default(now()) @map("uploaded_at")
  extractedText String?   @map("extracted_text")
  messages      Message[]

  @@map("files")
}

model PlatformConnection {
  id                   Int     @id @default(autoincrement())
  userId               Int     @map("user_id")
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform             String
  credentialsEncrypted String? @map("credentials_encrypted")
  platformUserId       String? @map("platform_user_id")
  isActive             Boolean @default(true) @map("is_active")

  @@map("platform_connections")
}

model AIProvider {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerType String   @map("provider_type")
  name         String
  apiBaseUrl   String   @map("api_base_url")
  apiKey       String   @map("api_key")
  modelId      String   @map("model_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ai_providers")
}

model SystemSetting {
  id       Int     @id @default(autoincrement())
  key      String  @unique
  value    String?
  isActive Boolean @default(true) @map("is_active")

  @@map("system_settings")
}

model Embedding {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  referenceId String   @map("reference_id")
  collection  String
  document    String
  embedding   Json
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([referenceId, collection])
  @@map("embeddings")
}
