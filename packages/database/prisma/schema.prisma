datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  role          String   @default("user")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  sessions      Session[]
  accounts      Account[]
  messages      Message[]
  files         File[]
  platforms     PlatformConnection[]
  aiProviders   AIProvider[]
  ownedWorkspace  Workspace?        @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  notifications    Notification[]
  notificationsSent Notification[] @relation("NotificationSender")

  @@map("users")
}

model Workspace {
  id         String   @id @default(uuid())
  name       String
  ownerId    String   @unique @map("owner_id")
  owner      User     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  inviteCode String   @unique @map("invite_code")
  createdAt  DateTime @default(now()) @map("created_at")
  members    WorkspaceMember[]
  aiProviders AIProvider[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("member")
  joinedAt    DateTime @default(now()) @map("joined_at")

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verifications")
}

model Message {
  id                Int      @id @default(autoincrement())
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          String
  senderId          String   @map("sender_id")
  senderName        String?  @map("sender_name")
  content           String?
  messageType       String   @default("text") @map("message_type")
  fileId            Int?     @map("file_id")
  file              File?    @relation(fields: [fileId], references: [id], onDelete: SetNull)
  platformMessageId String?  @map("platform_message_id")
  isOutgoing        Boolean  @default(false) @map("is_outgoing")
  timestamp         DateTime @default(now())
  ragSources        Json?    @map("rag_sources")

  @@map("messages")
}

model File {
  id            Int       @id @default(autoincrement())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName  String    @map("original_name")
  storageUrl    String    @map("storage_url")
  fileType      String    @map("file_type")
  folder        String?
  sizeBytes     BigInt    @map("size_bytes")
  uploadedAt    DateTime  @default(now()) @map("uploaded_at")
  extractedText String?   @map("extracted_text")
  messages      Message[]

  @@map("files")
}

model PlatformConnection {
  id                   Int     @id @default(autoincrement())
  userId               String  @map("user_id")
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform             String
  credentialsEncrypted String? @map("credentials_encrypted")
  platformUserId       String? @map("platform_user_id")
  isActive             Boolean @default(true) @map("is_active")

  @@map("platform_connections")
}

model AIProvider {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId  String?  @map("workspace_id")
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scope        String   @default("personal")
  providerType String   @map("provider_type")
  name         String
  apiBaseUrl   String   @map("api_base_url")
  apiKey       String   @map("api_key")
  modelId      String   @map("model_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ai_providers")
}

model SystemSetting {
  id       Int     @id @default(autoincrement())
  key      String  @unique
  value    String?
  isActive Boolean @default(true) @map("is_active")

  @@map("system_settings")
}

model Embedding {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  referenceId String   @map("reference_id")
  collection  String
  document    String
  embedding   Json
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([referenceId, collection])
  @@map("embeddings")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderId  String   @map("sender_id")
  sender    User     @relation("NotificationSender", fields: [senderId], references: [id], onDelete: Cascade)
  type      String   @default("info")
  title     String
  message   String?
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
