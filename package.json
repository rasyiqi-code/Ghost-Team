{
  "name": "ghost-team",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:generate": "bun --cwd packages/database prisma generate",
    "db:push": "bun --cwd packages/database prisma db push",
    "db:migrate": "bun --cwd packages/database prisma migrate dev"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "turbo": "^2.5.0",
    "typescript": "~6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["*"]
  },
  "engines": {
    "node": ">=22"
  }
}
