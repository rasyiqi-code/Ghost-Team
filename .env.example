# Ghost Relay — Environment Configuration
APP_NAME=ghost-relay
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://ghost:changeme@localhost:5433/ghost_relay

# Redis (empty = in-process task queue)
REDIS_URL=

# Auth
JWT_SECRET_KEY=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Seeder (used only when database is empty)
ADMIN_EMAIL=admin@ghost.local
ADMIN_PASSWORD=admin123

# Encryption (auto-generated if empty)
ENCRYPTION_KEY=your-encryption-key
CRYPTO_SALT=your-crypto-salt

# CORS
CORS_ORIGINS=["*"]

# AI Provider (fallback when no DB providers configured)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_AUDIO_MODEL=qwen-audio-turbo

# Storage
STORAGE_DIR=/tmp/ghost-storage

# Platform Integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=ghost-relay-verify
WHATSAPP_APP_SECRET=

# Frontend build directory (auto-detected if empty)
FRONTEND_DIR=

# Public URL (for webhook URLs shown in Settings UI)
PUBLIC_URL=
